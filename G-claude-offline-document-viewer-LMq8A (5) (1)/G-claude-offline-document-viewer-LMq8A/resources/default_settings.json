{
    "general": {
        "language": "ru",
        "theme": "light",
        "restoreSession": true,
        "showHomeOnStartup": true,
        "recentFilesLimit": 50
    },
    "viewer": {
        "defaultViewMode": "continuous",
        "defaultFitMode": "fitWidth",
        "defaultZoom": 1.0,
        "continuousScrollGap": 8,
        "showPageBorders": true,
        "backgroundColor": "#808080",
        "smoothScrolling": true,
        "pageBufferBefore": 2,
        "pageBufferAfter": 3
    },
    "display": {
        "brightness": 0.0,
        "contrast": 1.0,
        "gamma": 1.0,
        "invertColors": false,
        "grayscale": false,
        "nightMode": false
    },
    "annotations": {
        "defaultHighlightColor": "#FFFF00",
        "defaultInkColor": "#FF0000",
        "defaultInkWidth": 2.0,
        "defaultTextSize": 12,
        "showAnnotations": true,
        "autoSave": true
    },
    "ocr": {
        "language": "rus",
        "deskew": true,
        "denoise": true,
        "binarize": true,
        "autoOrientationDetect": true
    },
    "print": {
        "defaultScaling": "shrinkToFit",
        "printAnnotations": true,
        "autoRotate": true
    },
    "performance": {
        "pageCacheMemoryMB": 300,
        "renderThreads": 2,
        "thumbnailSize": 200,
        "progressiveRender": true
    },
    "logging": {
        "level": "info",
        "maxLogSizeMB": 10,
        "enableCrashDumps": true
    }
}
