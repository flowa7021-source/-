{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "docvision",
  "version": "0.1.0",
  "description": "Offline multi-format document viewer and annotator for Windows",
  "license": "AGPL-3.0-or-later",
  "supports": "windows & x64",
  "dependencies": [
    "nlohmann-json",
    "sqlite3",
    {
      "name": "mupdf",
      "default-features": false
    },
    "qpdf",
    "djvulibre",
    {
      "name": "tesseract",
      "default-features": false,
      "features": ["plainc"]
    },
    "leptonica",
    "libzip",
    "libjpeg-turbo",
    "libpng",
    "stb"
  ]
}
